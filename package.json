{
  "name": "@glz/maintenance",
  "version": "0.5.0",
  "description": "Reporter de errores hacia GLZ Maintenance (alternativa propia a Sentry, sin terceros)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./salud": {
      "types": "./dist/salud.d.ts",
      "default": "./dist/salud.js"
    }
  },
  "files": ["dist"],
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npx --yes tsx --test src/*.test.ts"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.0",
    "typescript": "^6.0.3"
  }
}
