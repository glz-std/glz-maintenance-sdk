{
  "name": "@glz/maintenance",
  "version": "0.4.0",
  "description": "Reporter de errores hacia GLZ Maintenance (alternativa propia a Sentry, sin terceros)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./salud": {
      "types": "./dist/salud.d.ts",
      "default": "./dist/salud.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.0",
    "typescript": "^5.9.3"
  }
}
