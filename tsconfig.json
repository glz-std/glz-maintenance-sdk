{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // TS6 dejó de auto-incluir los tipos globales de @types/node cuando el lib
    // contiene DOM (cambio de comportamiento de la inclusión automática de @types).
    // El código usa el global `process` (config.ts), así que se declara explícito.
    "types": ["node"],
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  // Los tests (*.test.ts) corren con tsx (node:test); NO se compilan a dist/
  // (el dist/ commiteado solo lleva el SDK publicable; el CI verifica el sync).
  "exclude": ["src/**/*.test.ts"]
}
